.vehica-car-card__inner {
    background: #000000;
}
.vehica-featured-v1 .vehica-featured-v1__vehicles .vehica-featured-v1__big-card .vehica-car-card__content {
    background: #000000;
}
.vehica-heading {
    align-items: flex-start;
}
.elementor-13444 .elementor-element.elementor-element-c5bb9ce .vehica-menu__desktop {
    background: #ffffff0d ;
    /* backdrop-filter: blur(20px); */
}
input:focus,
textarea:focus,
select:focus {
	border-color: #D6AD66 !important;
}

.red-gradient {
    background: linear-gradient(135deg, #D6AD66 0%, #D6AD66 50%, #D6AD66 100%);
    opacity: 0.1;
}

.glass-effect {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.luxury-gradient {
    background: linear-gradient(135deg, #2a2a2a 0%, #D6AD66 50%, #2a2a2a 100%);
}
.vehica-tabs-top-v2__heading{
	color: #fff
}





/*  To be used in future */
.red-gradient {
    background: linear-gradient(135deg, #D6AD66 0%, #D6AD66 50%, #D6AD66 100%);
}
.hover-lift {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
.hover-lift:hover {
    transform: translateY(-12px);
    box-shadow: 0 25px 50px rgba(214, 173, 102, 0.3);
}
.parallax-bg {
    background-attachment: fixed;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
}
.red-glow {
    box-shadow: 0 0 30px rgba(214, 173, 102, 0.3);
}
.floating-animation {
    animation: float 6s ease-in-out infinite;
}
@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
}
.text-brand-red { color: #D6AD66; }
.bg-brand-red { background-color: #D6AD66; }
.border-brand-red { border-color: #D6AD66; }
.hover\:bg-brand-red:hover { background-color: #D6AD66; }
.hover\:text-brand-red:hover { color: #D6AD66; }
.focus\:border-brand-red:focus { border-color: #D6AD66; }

/* Main accordion container - glassy background */
.elementor-accordion {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    opacity: 1;
    transform: translateY(0px);
    transition: opacity 0.6s, transform 0.6s;
}

/* Individual accordion items */
.elementor-accordion-item {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    margin-bottom: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
}

.elementor-accordion-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(214, 173, 102, 0.2);
    border-color: rgba(214, 173, 102, 0.3);
}

.elementor-accordion-item:last-child {
    margin-bottom: 0;
}

/* Accordion title styling */
.elementor-tab-title {
    background: transparent !important;
    color: white !important;
    padding: 20px 24px !important;
    font-size: 18px !important;
    font-weight: 600 !important;
    border: none !important;
    transition: all 0.3s ease !important;
}

.elementor-tab-title:hover {
    background: rgba(214, 173, 102, 0.1) !important;
}

.elementor-tab-title.elementor-active {
    background: rgba(214, 173, 102, 0.2) !important;
    color: #D6AD66 !important;
}

/* Accordion title text */
.elementor-accordion-title {
    color: white !important;
    text-decoration: none !important;
    font-weight: 600 !important;
}

.elementor-tab-title.elementor-active .elementor-accordion-title {
    color: #D6AD66 !important;
}

/* Accordion icon styling */
.elementor-accordion-icon {
    color: #D6AD66 !important;
}

.elementor-accordion-icon svg {
    fill: #D6AD66 !important;
    width: 16px !important;
    height: 16px !important;
    transition: transform 0.3s ease !important;
}

.elementor-tab-title.elementor-active .elementor-accordion-icon svg {
    transform: rotate(180deg) !important;
}

/* Accordion content styling */
.elementor-tab-content {
    background: rgba(0, 0, 0, 0.2) !important;
    color: #e5e7eb !important;
    padding: 24px !important;
    border-top: 1px solid rgba(255, 255, 255, 0.1) !important;
    line-height: 1.6 !important;
}

.elementor-tab-content p {
    color: #e5e7eb !important;
    margin-bottom: 12px !important;
    line-height: 1.6 !important;
}

.elementor-tab-content p:last-child {
    margin-bottom: 0 !important;
}

/* Hover effects for better interactivity */
.elementor-accordion-item:hover .elementor-tab-title {
    background: rgba(214, 173, 102, 0.1) !important;
}

.elementor-accordion-item:hover .elementor-accordion-icon svg {
    transform: scale(1.1) !important;
}

/* Active state enhancements */
.elementor-accordion-item:has(.elementor-tab-title.elementor-active) {
    border-color: rgba(214, 173, 102, 0.4) !important;
    box-shadow: 0 8px 25px rgba(214, 173, 102, 0.15) !important;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .elementor-accordion {
        padding: 16px;
        border-radius: 12px;
    }

    .elementor-tab-title {
        padding: 16px 20px !important;
        font-size: 16px !important;
    }

    .elementor-tab-content {
        padding: 20px !important;
    }
}

.elementor-12599 .elementor-element.elementor-element-c5bb9ce .vehica-logo img {
     max-height: 200px !important;
    height: 80px !important;
    /* height:32px; */
}

.elementor-13444 .elementor-element.elementor-element-c5bb9ce .vehica-logo img {
  max-height: 200px !important;
    height: 80px !important;
}		</style>
