    <div><div class="stock-locator section">



<div id="stock-locator-root" data-prop="{&#34;bundleURL&#34;:&#34;https://d3v8m1hdntzgol.cloudfront.net/seat/index.js&#34;,&#34;nedcFirstRangeFirstValue&#34;:&#34;consumption-COMBINED-NEDC&#34;,&#34;importersPath&#34;:&#34;https://tools.seat.co.uk/forms/stock-locator&#34;,&#34;stockFragmentRoot&#34;:&#34;/content/dam/content-fragments/markets/countries/gb/seat/en/services/stock-locator/stock-l&#34;,&#34;css&#34;:&#34;https://d3v8m1hdntzgol.cloudfront.net/seat/main.css&#34;,&#34;defaultVehicleFilter&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/icon_not_found.png&#34;,&#34;sling:resourceType&#34;:&#34;seatComponents/components/stock-locator&#34;,&#34;nedcSecondRangeFirstValue&#34;:&#34;consumption-COMBINED-NEDC&#34;,&#34;textIsRich&#34;:[&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;,&#34;true&#34;],&#34;defaultColorFilter&#34;:&#34;/content/dam/public/seat-website/generic/icons/stock-locator-icons/color-unavailable.png&#34;,&#34;stockHero&#34;:{&#34;findYourCarLabel&#34;:&#34;Find your perfect new SEAT&#34;},&#34;orderByLabels&#34;:{&#34;orderbyHighestPriceLabel&#34;:&#34;Price (high-low)&#34;,&#34;orderbyLabel&#34;:&#34;Sort by:&#34;,&#34;orderbyDistanceLabel&#34;:&#34;Nearest&#34;,&#34;orderbyLowestPriceLabel&#34;:&#34;Price (low-high)&#34;,&#34;orderVehicleLabel&#34;:&#34;cars&#34;,&#34;filterButtonLabel&#34;:&#34;Filters&#34;,&#34;defaultOrder&#34;:{&#34;direction&#34;:&#34;ASC&#34;,&#34;field&#34;:&#34;PRICE_SALE&#34;}},&#34;cardLabels&#34;:{&#34;i18n_dealerPriceCardLabel&#34;:&#34;Total price&#34;,&#34;wltpFirstRangeFirstValue&#34;:&#34;consumption-COMBINED&#34;,&#34;currency&#34;:&#34;£&#34;,&#34;showCurrencyBefore&#34;:&#34;true&#34;,&#34;recomendedPriceLabel&#34;:&#34;OTR&#34;},&#34;priceCard&#34;:{&#34;consumptionLabel&#34;:&#34;WLTP Fuel Consumption (Combined)&#34;,&#34;wltpIconTwo&#34;:&#34;/content/dam/public/seat-website/generic/icons/stock-locator-icons/mask.svg&#34;,&#34;emissionsLabel&#34;:&#34;WLTP CO₂ Emissions (Combined)&#34;,&#34;efficiencyLabel&#34;:&#34;Efficiency &#34;,&#34;electricalLabel&#34;:&#34;Electric consumption:&#34;,&#34;priceCardPrimaryCtaClass&#34;:&#34;btn btn-standard btn-orange btn-block&#34;,&#34;priceCardPrimaryCtaTitle&#34;:&#34;Request a Test Drive&#34;,&#34;priceCardPrimaryCtaTarget&#34;:&#34;_self&#34;,&#34;priceCardCommissionLabel&#34;:&#34;Reference Number&#34;,&#34;currency&#34;:&#34;£&#34;,&#34;priceCardtotalLabel&#34;:&#34;Total price&#34;,&#34;wltpSecondRangeFirstValue&#34;:&#34;consumption-COMBINED&#34;,&#34;priceCardTertiaryCtaClass&#34;:&#34;link-arrow&#34;,&#34;priceCardTertiaryCtaTitle&#34;:&#34;Back to results&#34;,&#34;priceCardPrimaryCtaLink&#34;:&#34;/content/countries/gb/seat-website/en/home&#34;},&#34;loadMoreLabels&#34;:{&#34;ofLabel&#34;:&#34;of&#34;,&#34;loadMoreLabel&#34;:&#34;Load more&#34;,&#34;noResultsLabel&#34;:&#34;No results&#34;,&#34;showingLabel&#34;:&#34;Load more&#34;,&#34;goToTopLabel&#34;:&#34;Go to top&#34;},&#34;resultsPageDisclaimer&#34;:{&#34;disclaimerAvailable&#34;:&#34;true&#34;,&#34;copyBlock&#34;:&#34;&lt;p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aliquam euismod orci vel faucibus venenatis. Cras non malesuada diam. Integer eu hendrerit enim, vitae elementum tortor. Duis rhoncus scelerisque feugiat. Nulla at purus vitae mauris euismod pulvinar. Donec scelerisque mi magna, sed tincidunt risus eleifend id. Maecenas vulputate rutrum magna vitae egestas. Suspendisse potenti. Sed congue orci orci, at ultricies leo varius et. Aenean fringilla nibh augue, ut euismod ligula faucibus in. Sed suscipit commodo libero, quis bibendum nisl.&lt;/p>\r\n&lt;p>Aliquam eros nulla, vehicula id vulputate eget, mattis eget neque. Cras lobortis gravida magna, non iaculis justo fringilla vitae. Fusce ac ipsum quis nunc euismod hendrerit sit amet non tellus. Donec ut malesuada ante, in vulputate sapien. Donec in ligula a dui accumsan faucibus. Duis erat odio, vehicula porttitor dictum eget, cursus at ex. Curabitur accumsan tortor eget felis fringilla ultricies. Phasellus tristique massa in vestibulum egestas. Curabitur orci nibh, venenatis eget nisi et, ultricies malesuada lacus. Phasellus iaculis nec risus nec ultrices. Sed urna nulla, viverra euismod quam id, vehicula placerat urna. Nam imperdiet finibus orci non elementum. Sed nec nisl ultricies, dapibus velit at, sodales ante.&lt;/p>\r\n&#34;,&#34;showExpanded&#34;:&#34;true&#34;},&#34;productPageDisclaimer&#34;:{&#34;productDisclaimerAvailable&#34;:&#34;true&#34;,&#34;productCopyBlock&#34;:&#34;&lt;p>&lt;u>Legal note:&lt;/u>&lt;/p>\r\n&lt;p>The display of vehicles and search results does not create a contract or other binding obligation and is subject to change without notice. It is not an offer capable of acceptance.&lt;/p>\r\n&lt;p>Every effort has been made to ensure the accuracy of the information above. However, errors may occur and SEAT UK cannot guarantee the information provided will be up-to-date, accurate, complete and precise and does not assume liability for it. It is possible that vehicles may be incorrectly priced, described or pictured within this tool or may already be subject to other enquiries or may have been sold. Check with your local participating SEAT Retailer about items which may affect your decision to purchase.&lt;/p>\r\n&lt;p>Standard vehicle equipment is automatically populated from separate systems and sometimes may vary from the actual car. Always speak to the SEAT Retailer to confirm the most up to date availability, price, specification and other vehicle information before placing your order.&lt;/p>\r\n&lt;p>Lead times are indicative only.&lt;/p>\r\n&lt;p>Please check model availability and full specification details with your SEAT Retailer prior to ordering. Neither SEAT UK nor SEAT Retailers can accept contractual responsibility for your reliance on the information contained in the New Car Stock Locator Tool.&lt;/p>\r\n&lt;p>&lt;i>Reserve Online&lt;/i>&lt;/p>\r\n&lt;p>The &amp;quot;Reserve Online&amp;quot; option is not a vehicle order. Once you have completed the reservation process (in accordance with the &lt;a href=\&#34;https://www.seat.co.uk/about-seat/legal/new-car-reservation-terms\&#34;>terms and conditions&lt;/a>), you will receive an email to confirm that your request has been passed to the relevant SEAT Retailer. Once reserved, your vehicle will be reserved for a period of seven (7) days.&lt;/p>\r\n&lt;p>In order to reserve a vehicle, a credit card pre-authorisation of £99 is required. This pre-authorisation does not debit your bank account. The amount is blocked for a period of seven (7) days. After this period, the credit card pre-authorisation is automatically cancelled, without you having to act and without any further information from us or your bank. Please note the credit card pre-authorisation cannot be returned any sooner than the period imposed by your bank (please check with your bank for details).&lt;/p>\r\n&lt;p>Once your vehicle is reserved, it will be visible on the New Car Stock Locator Tool with a &amp;quot;reserved&amp;quot; banner. However, &lt;b>no &amp;quot;holds&amp;quot; will be placed on the car in the vehicle ordering system. It is, therefore, possible your vehicle may be offered to other customers and may be sold during the Reservation Period.&lt;/b>&lt;/p>\r\n&lt;p>The vehicle will only be removed from the New Car Stock Locator Tool when you have purchased it (i.e. when you have entered into an agreement for purchase of the vehicle).&lt;/p>\r\n&lt;p>After the seven (7) day reservation period, SEAT UK or the SEAT Retailer may offer the vehicle to other customers, even if your credit card pre-authorisation has not yet expired and the £99 is still blocked within your account.&lt;/p>\r\n&lt;p>The vehicles displayed are not updated in real time and so it is possible that you may reserve a vehicle which may already be subject to other enquiries or reservations or may have already been sold by SEAT UK or the SEAT Retailer or is otherwise not available. In this instance, your SEAT Retailer will respond to your reservation accordingly, making you aware of alternative vehicles that are available.&lt;/p>\r\n&lt;p>The sale agreement for any vehicle reserved is not concluded on the Site and you will need to visit the applicable SEAT Retailer to make your purchase.&lt;/p>\r\n&lt;p>&lt;b>* If you are reserving a SEAT vehicle: &lt;/b>You will need to place an order to purchase the vehicle with your chosen SEAT Retailer.&lt;/p>\r\n&lt;p>We may close the reservation scheme to new applicants for any reason at any time. We will endeavour to provide notice on the Site before closing access to the scheme.&lt;/p>\r\n&lt;p>&lt;i>Pricing, figures and specification&lt;/i>&lt;/p>\r\n&lt;p>&lt;b>* If you are reserving a SEAT vehicle &lt;/b>then prices shown are the manufacturer&#39;s recommended On The Road (OTR) retail price. Actual prices are set by SEAT authorised retailers in their sole discretion – always obtain these prices from your chosen SEAT Retailer. Recommended On-The-Road (OTR) retail prices include: delivery charge, number plates, new vehicle registration fee, the first year&#39;s Vehicle Excise Duty and VAT (calculated at 20%).&lt;/p>\r\n&lt;p>Prices, specifications and other vehicle information are subject to change without notice and may therefore differ at the time of order from the prices and other vehicle information displayed in the New Car Stock Locator Tool. Please speak to the relevant SEAT Retailer to confirm the most up to date availability, price, specification and other vehicle information.&lt;/p>\r\n&lt;p>Performance figures and specifications relating to SEAT vehicles are indicative only and performance cannot be guaranteed. Performance figures and specifications may be updated on this site from time to time. The applicable SEAT Retailer can always provide you with the most up-to-date information available.&lt;/p>\r\n&lt;p>† All vehicles are tested according to WLTP technical procedures. Figures shown are for comparability purposes; only compare fuel consumption, range and CO2 and equivalent electric range figures with other vehicles tested to the same technical procedures. These figures may not reflect real life driving results, which will depend upon a number of factors including the accessories fitted (post-registration), variations in weather, driving styles, vehicle load (and, for battery electric vehicles, the starting charge of the battery). Figures for plug-in hybrid vehicles were obtained using a combination of battery power and fuel. Plug-in hybrid vehicles require mains electricity for charging. Figures for battery electric vehicles were obtained after the battery had been fully charged. Battery electric vehicles require mains electricity for charging. Zero emissions while driving.&lt;/p>\r\n&lt;p>All figures quoted are subject to change due to ongoing approvals/changes and range figures may include options not available in the UK. Please consult your participating SEAT Retailer for further information.&lt;/p>\r\n&lt;p>Technical and connected features may be subject to system limits and requirements, including compatibility, network or wi-fi coverage, restriction and app-download, subscription to digital services, etc. Please visit our SEAT Connect page for more information on these features and relevant terms and conditions.&lt;/p>\r\n&lt;p>Speed and system limits apply to driver assistance technologies. Driver assistance only – driver must pay attention to the road and retain control at all times.&lt;/p>\r\n&lt;p>Please note it is not possible to retrospectively fit a tow bar if the car is not fitted with tow bar preparation.&lt;/p>\r\n&lt;p>Where a vehicle is described as &amp;quot;&lt;i>National stock – available at any Retailer&lt;/i>&amp;quot; the cars displayed are not currently at any particular SEAT Retailer and are available to purchase from all participating SEAT Retailers. If you wish to select a specific SEAT Retailer, you will need to enter a different postcode. Subject to availability, your local participating SEAT Retailer will need to purchase the vehicle from SEAT UK ahead of your purchase.&lt;/p>\r\n&#34;,&#34;productShowExpanded&#34;:&#34;true&#34;},&#34;mobileLabels&#34;:{&#34;filterCancelButtonLabel&#34;:&#34;Cancel&#34;,&#34;seeButtonLabel&#34;:&#34;View available&#34;,&#34;deleteButtonLabel&#34;:&#34;Clear&#34;,&#34;deleteFilterButtonLabel&#34;:&#34;Remove filters&#34;,&#34;carButtonLabel&#34;:&#34;cars&#34;,&#34;titleFilterLabel&#34;:&#34;Filter results&#34;,&#34;subtitleFilterLabel&#34;:&#34;Find your car&#34;,&#34;commomFilterVisible&#34;:&#34;true&#34;},&#34;locationFilter&#34;:{&#34;locationLabels&#34;:{&#34;searchNearToLabel&#34;:&#34;Search by postcode or location&#34;,&#34;distanceUnit&#34;:&#34;miles&#34;,&#34;orderLocationFilter&#34;:&#34;0&#34;,&#34;locationFilterVisible&#34;:&#34;true&#34;,&#34;radioTextLabel&#34;:&#34;Prepared to travel&#34;,&#34;locationNoResult&#34;:&#34;No results found. Please try entering a valid address. &#34;,&#34;searchBoxPlaceholderLabel&#34;:&#34;e.g. MK14 5AN or Milton Keynes&#34;,&#34;retailerTypeLabel&#34;:&#34;Retailer Type&#34;,&#34;locationAccordionLabel&#34;:&#34;Location&#34;,&#34;locationTryAgain&#34;:&#34;Try again&#34;},&#34;locationRegionCodes&#34;:[&#34;UK&#34;],&#34;locationBullets&#34;:[&#34;10&#34;,&#34;50&#34;,&#34;100&#34;,&#34;150&#34;,&#34;200&#34;]},&#34;priceFilter&#34;:{&#34;financingFilterVisible&#34;:&#34;false&#34;,&#34;orderPriceFilter&#34;:&#34;1&#34;,&#34;showFinancingFilter&#34;:&#34;false&#34;,&#34;priceTextLabel&#34;:&#34;Set your price range&#34;,&#34;priceAccordionLabel&#34;:&#34;Price&#34;,&#34;priceFilterVisible&#34;:&#34;true&#34;,&#34;onlineCarsFilter&#34;:{&#34;onlineCarsFilterVisible&#34;:&#34;false&#34;}},&#34;modelFilterLabels&#34;:{&#34;orderVehicleFilter&#34;:&#34;1&#34;,&#34;vehicleFilterVisible&#34;:&#34;true&#34;,&#34;vehicleAccordionLabel&#34;:&#34;Cars&#34;,&#34;vehicleTextLabel&#34;:&#34;Choose your car(s)&#34;},&#34;engineFilter&#34;:{&#34;engineFuelLabel&#34;:&#34;Fuel Type&#34;,&#34;enginePowerRangeLabel&#34;:&#34;Engine power (PS)&#34;,&#34;orderEngineFilter&#34;:&#34;2&#34;,&#34;powerUnit&#34;:&#34;PS&#34;,&#34;engineTransmissionLabel&#34;:&#34;Transmission&#34;,&#34;engineAccordionLabel&#34;:&#34;Engines&#34;,&#34;engineFilterVisible&#34;:&#34;true&#34;,&#34;certifiedPreOwned&#34;:{&#34;certifiedPreOwnedVisible&#34;:&#34;false&#34;}},&#34;colorFilterLabels&#34;:{&#34;colorTextLabel&#34;:&#34;Choose your colour(s)&#34;,&#34;colorAccordionLabel&#34;:&#34;Colour&#34;,&#34;colorFilterVisible&#34;:&#34;true&#34;,&#34;orderColorFilter&#34;:&#34;4&#34;},&#34;tagListLabels&#34;:{&#34;allModelsLabel&#34;:&#34;All models&#34;,&#34;deleteFiltersLabel&#34;:&#34;Delete filters&#34;},&#34;twoColumns&#34;:{&#34;assetRootXLRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/x-large/stacked-xl.png&#34;,&#34;assetRootSRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/small/stacked-s.png&#34;,&#34;assetRootMNoRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/medium/stacked-m.png&#34;,&#34;eyebrow&#34;:&#34;Available at any Retailer&#34;,&#34;assetRootXLNoRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/x-large/stacked-xl.png&#34;,&#34;assetRootLNoRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/large/stacked-l.png&#34;,&#34;assetRootSNoRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/small/stacked-s.png&#34;,&#34;primaryCtaClass&#34;:&#34;btn btn-standard btn-black&#34;,&#34;assetRootLRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/large/stacked-l.png&#34;,&#34;assetRootMRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/medium/stacked-m.png&#34;},&#34;formSettings&#34;:{&#34;modelDescriptionFormParam&#34;:&#34;modelDescription&#34;,&#34;partnerIdFormParam&#34;:&#34;PartnerId&#34;,&#34;formPath&#34;:&#34;https://tools.seat.co.uk/forms/stock-locator&#34;,&#34;vinNumberFormParam&#34;:&#34;vin&#34;,&#34;colorFormParam&#34;:&#34;colour&#34;,&#34;dealerFormParam&#34;:&#34;dealerNumber&#34;,&#34;modelFormParam&#34;:&#34;modelName&#34;,&#34;modelIdFormParam&#34;:&#34;modelId&#34;,&#34;formBackLabel&#34;:&#34;Back to results&#34;},&#34;engineSection&#34;:{&#34;emissionsTooltip&#34;:&#34;false&#34;,&#34;wltpLabels&#34;:{&#34;co2efficiencyWLTP&#34;:&#34;CO₂ Emissions&#34;,&#34;electricalConsumptionWLTP&#34;:&#34;Electrical Consumption&#34;,&#34;combinedConsumptionWLTP&#34;:&#34;WLTP Consumption Combined&#34;,&#34;wltpConsumtionTitle&#34;:&#34;WLTP Consumption&#34;,&#34;fuelTypeLabelWLTP&#34;:&#34;Fuel type&#34;,&#34;highConsumptionLabelWLTP&#34;:&#34;WLTP Consumption High&#34;,&#34;extrahighConsumptionLabelWLTP&#34;:&#34;WLTP Consumption Extra High&#34;,&#34;wltpEfficiency&#34;:&#34;WLTP Emissions&#34;,&#34;wltp&#34;:&#34;WLTP ¹&#34;,&#34;lowConsumtionLabelWLTP&#34;:&#34;WLTP Consumption Low&#34;,&#34;wltpConsumptionTitle&#34;:&#34;WLTP Consumption&#34;,&#34;wltpEfficiencyTitle&#34;:&#34;WLTP Emissions&#34;,&#34;mediumConsumptionLabelWLTP&#34;:&#34;WLTP Consumption Medium&#34;},&#34;nedcLabels&#34;:{&#34;electricalConsumptionNEDC&#34;:&#34;Electrical consumption&#34;,&#34;extraUrbanConsumptionLabelNEDC&#34;:&#34;Extra-Urban&#34;,&#34;combinedConsumptionNEDC&#34;:&#34;Combined&#34;,&#34;emissionsTitleNEDC&#34;:&#34;Emissions&#34;,&#34;nedcConsumptionTitle&#34;:&#34;NEDC Consumption&#34;,&#34;urbanConsumtionLabelNEDC&#34;:&#34;Urban&#34;},&#34;nedc&#34;:{}},&#34;stacked&#34;:{&#34;stackedAvailable&#34;:&#34;true&#34;,&#34;assetRootXLRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/x-large/stacked-xl.png&#34;,&#34;assetRootSRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/small/stacked-s.png&#34;,&#34;assetRootMNoRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/medium/stacked-m.png&#34;,&#34;assetRootXLNoRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/x-large/stacked-xl.png&#34;,&#34;assetRootLNoRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/large/stacked-l.png&#34;,&#34;assetRootSNoRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/small/stacked-s.png&#34;,&#34;positionStacked&#34;:&#34;right&#34;,&#34;assetRootLRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/large/stacked-l.png&#34;,&#34;eyebrowStacked&#34;:&#34;Available at the Retailer of your choice&#34;,&#34;primaryCtaStyleStacked&#34;:&#34;standard&#34;,&#34;assetRootMRetina&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/one-paragraph/medium/stacked-m.png&#34;,&#34;primaryCtaTargetStacked&#34;:&#34;_self&#34;,&#34;primaryCtaColorStacked&#34;:&#34;black&#34;,&#34;backgroundColorPickerStacked&#34;:&#34;#B11C18&#34;},&#34;financingFilter&#34;:{},&#34;kilometerYearFilter&#34;:{&#34;order&#34;:&#34;5&#34;,&#34;visible&#34;:&#34;true&#34;,&#34;i18n_kilometerLabel&#34;:&#34;Mileage&#34;,&#34;i18n_accordionLabel&#34;:&#34;Age &amp; Milage&#34;,&#34;i18n_yearLabel&#34;:&#34;Age&#34;},&#34;virtualShowRoomFilter&#34;:{&#34;virtualShowRoomFilterVisible&#34;:&#34;false&#34;},&#34;equipmentFilterLabels&#34;:{&#34;equipmentFilterVisible&#34;:&#34;false&#34;,&#34;equipmentTextLabel&#34;:&#34;Options&#34;,&#34;equipmentInfotainment&#34;:{&#34;infotainmentFilterVisible&#34;:&#34;false&#34;,&#34;infotainmentTextLabel&#34;:&#34;Infotainment&#34;},&#34;equipmentInterior&#34;:{&#34;interiorFilterVisible&#34;:&#34;false&#34;,&#34;interiorTextLabel&#34;:&#34;Interior&#34;},&#34;equipmentExterior&#34;:{&#34;exteriorTextLabel&#34;:&#34;Exterior&#34;,&#34;exteriorFilterVisible&#34;:&#34;false&#34;},&#34;equipmentTechnology&#34;:{&#34;technologyTextLabel&#34;:&#34;Technology &amp; security&#34;,&#34;technologyFilterVisible&#34;:&#34;false&#34;}},&#34;equipmentFavorites&#34;:{},&#34;tiredLabel&#34;:{},&#34;productPage&#34;:{&#34;toolTipType&#34;:&#34;NEDC&#34;,&#34;showPerformanceModule&#34;:&#34;true&#34;,&#34;showEmissionNEDCVisible&#34;:&#34;false&#34;,&#34;showRoomVisible&#34;:&#34;false&#34;,&#34;showEmissionModule&#34;:&#34;false&#34;,&#34;galleryHighlightsTitle&#34;:&#34;Highlights&#34;,&#34;showEmissionWLTPVisible&#34;:&#34;true&#34;,&#34;highlightsMode&#34;:&#34;europaWLTP&#34;,&#34;emissionDataSource&#34;:&#34;europaWLTP&#34;,&#34;seeMoreGalleryPhotos&#34;:&#34;See all&#34;,&#34;showBuyOnlineButton&#34;:&#34;false&#34;,&#34;buyOnline&#34;:{&#34;oneshopLink&#34;:{}},&#34;equipmentDesign&#34;:{&#34;equipmentDesignExteriorColor&#34;:&#34;Exterior colour&#34;,&#34;showEquipmentDesign&#34;:&#34;true&#34;,&#34;equipmentDesignWheels&#34;:&#34;Wheels&#34;,&#34;equipmentDesignTitle&#34;:&#34;Equipment&#34;,&#34;equipmentDesignUpholstery&#34;:&#34;Upholstery&#34;},&#34;deliveryTime&#34;:{&#34;deliveryTimeTooltipVisible&#34;:&#34;false&#34;,&#34;deliveryTimeMode&#34;:&#34;minDeliveryTime&#34;,&#34;deliveryTimeVisible&#34;:&#34;false&#34;},&#34;history&#34;:{&#34;showHistoryModule&#34;:&#34;false&#34;},&#34;testDrive&#34;:{&#34;showTestDrive&#34;:&#34;false&#34;,&#34;i18nTestDriveTitle&#34;:&#34;Test Drive&#34;,&#34;testDriveCtaTarget&#34;:&#34;_self&#34;,&#34;testDriveButton&#34;:&#34;Book a Test Drive&#34;},&#34;footerPage&#34;:{&#34;staticDisclaimer&#34;:&#34;&lt;p>&lt;u>Legal note:&lt;/u>&lt;/p>\r\n&lt;p>The display of vehicles and search results does not create a contract or other binding obligation and is subject to change without notice. It is not an offer capable of acceptance.&lt;/p>\r\n&lt;p>Every effort has been made to ensure the accuracy of the information above. However, errors may occur and SEAT UK cannot guarantee the information provided will be up-to-date, accurate, complete and precise and does not assume liability for it. It is possible that vehicles may be incorrectly priced, described or pictured within this tool or may already be subject to other enquiries or may have been sold. Check with your local participating SEAT Retailer about items which may affect your decision to purchase.&lt;/p>\r\n&lt;p>Standard vehicle equipment is automatically populated from separate systems and sometimes may vary from the actual car. Always speak to the SEAT Retailer to confirm the most up to date availability, price, specification and other vehicle information before placing your order.&lt;/p>\r\n&lt;p>Lead times are indicative only.&lt;/p>\r\n&lt;p>&lt;i>Reserve Online&lt;/i>&lt;/p>\r\n&lt;p>The &amp;quot;Reserve Online&amp;quot; option is not a vehicle order. Once you have completed the reservation process (in accordance with the&amp;nbsp;&lt;a href=\&#34;https://www.seat.co.uk/about-seat/legal/new-car-reservation-terms\&#34;>terms and conditions&lt;/a>), you will receive an email to confirm that your request has been passed to the relevant SEAT Retailer. Once reserved, your vehicle will be reserved for a period of seven (7) days.&lt;/p>\r\n&lt;p>In order to reserve a vehicle, a credit card pre-authorisation of £99 is required. This pre-authorisation does not debit your bank account. The amount is blocked for a period of seven (7) days. After this period, the credit card pre-authorisation is automatically cancelled, without you having to act and without any further information from us or your bank. Please note the credit card pre-authorisation cannot be returned any sooner than the period imposed by your bank (please check with your bank for details).&lt;/p>\r\n&lt;p>Once your vehicle is reserved, it will be visible on the New Car Stock Locator Tool with a &amp;quot;reserved&amp;quot; banner. However,&amp;nbsp;no &amp;quot;holds&amp;quot; will be placed on the car in the vehicle ordering system. It is, therefore, possible your vehicle may be offered to other customers and may be sold during the Reservation Period.&lt;/p>\r\n&lt;p>The vehicle will only be removed from the New Car Stock Locator Tool when you have purchased it (i.e. when you have entered into an agreement for purchase of the vehicle).&lt;/p>\r\n&lt;p>After the seven (7) day reservation period, SEAT UK or the SEAT Retailer may offer the vehicle to other customers, even if your credit card pre-authorisation has not yet expired and the £99 is still blocked within your account.&lt;/p>\r\n&lt;p>The vehicles displayed are not updated in real time and so it is possible that you may reserve a vehicle which may already be subject to other enquiries or reservations or may have already been sold by SEAT UK or the SEAT Retailer or is otherwise not available. In this instance, your SEAT Retailer will respond to your reservation accordingly, making you aware of alternative vehicles that are available.&lt;/p>\r\n&lt;p>The sale agreement for any vehicle reserved is not concluded on the Site and you will need to visit the applicable SEAT Retailer to make your purchase.&lt;/p>\r\n&lt;p>* If you are reserving a SEAT vehicle:&amp;nbsp;You will need to place an order to purchase the vehicle with your chosen SEAT Retailer.&lt;/p>\r\n&lt;p>We may close the reservation scheme to new applicants for any reason at any time. We will endeavour to provide notice on the Site before closing access to the scheme.&lt;/p>\r\n&lt;p>&lt;i>Pricing, figures and specification&lt;/i>&lt;/p>\r\n&lt;p>* If you are reserving a SEAT vehicle&amp;nbsp;then prices shown are the manufacturer&#39;s recommended On The Road (OTR) retail price. Actual prices are set by SEAT authorised retailers in their sole discretion – always obtain these prices from your chosen SEAT Retailer. Recommended On-The-Road (OTR) retail prices include: delivery charge, number plates, new vehicle registration fee, the first year&#39;s Vehicle Excise Duty and VAT (calculated at 20%).&lt;/p>\r\n&lt;p>Prices, specifications and other vehicle information are subject to change without notice and may therefore differ at the time of order from the prices and other vehicle information displayed in the New Car Stock Locator Tool. Please speak to the relevant SEAT Retailer to confirm the most up to date availability, price, specification and other vehicle information.&lt;/p>\r\n&lt;p>Performance figures and specifications relating to SEAT vehicles are indicative only and performance cannot be guaranteed. Performance figures and specifications may be updated on this site from time to time. The applicable SEAT Retailer can always provide you with the most up-to-date information available.&lt;/p>\r\n&lt;p>† All vehicles are tested according to WLTP technical procedures. Figures shown are for comparability purposes; only compare fuel consumption, range and CO2 and equivalent electric range figures with other vehicles tested to the same technical procedures. These figures may not reflect real life driving results, which will depend upon a number of factors including the accessories fitted (post-registration), variations in weather, driving styles, vehicle load (and, for battery electric vehicles, the starting charge of the battery). Figures for plug-in hybrid vehicles were obtained using a combination of battery power and fuel. Plug-in hybrid vehicles require mains electricity for charging. Figures for battery electric vehicles were obtained after the battery had been fully charged. Battery electric vehicles require mains electricity for charging. Zero emissions while driving.&lt;/p>\r\n&lt;p>All figures quoted are subject to change due to ongoing approvals/changes and range figures may include options not available in the UK. Please consult your participating SEAT Retailer for further information.&lt;/p>\r\n&lt;p>Technical and connected features may be subject to system limits and requirements, including compatibility, network or wi-fi coverage, restriction and app-download, subscription to digital services, etc. Please visit our SEAT Connect page for more information on these features and relevant terms and conditions.&lt;/p>\r\n&lt;p>Speed and system limits apply to driver assistance technologies. Driver assistance only – driver must pay attention to the road and retain control at all times.&lt;/p>\r\n&lt;p>Please note it is not possible to retrospectively fit a tow bar if the car is not fitted with tow bar preparation.&lt;/p>\r\n&lt;p>Where a vehicle is described as &amp;quot;&lt;i>National stock – available at any Retailer&lt;/i>&amp;quot; the cars displayed are not currently at any particular SEAT Retailer and are available to purchase from all participating SEAT Retailers. If you wish to select a specific SEAT Retailer, you will need to enter a different postcode. Subject to availability, your local participating SEAT Retailer will need to purchase the vehicle from SEAT UK ahead of your purchase.&lt;/p>\r\n&#34;,&#34;showWebcalcDisclaimer&#34;:&#34;false&#34;},&#34;brandServiceModule&#34;:{&#34;serviceCtaTarget&#34;:&#34;_self&#34;,&#34;showBrandServiceModule&#34;:&#34;false&#34;}},&#34;stockLocatorBanner&#34;:{&#34;bannerCtaTarget&#34;:&#34;_self&#34;,&#34;bannerVisible&#34;:&#34;false&#34;},&#34;testDrive&#34;:{&#34;showTestDrive&#34;:&#34;false&#34;},&#34;priceBoxModule&#34;:{&#34;priceBoxType&#34;:&#34;priceBox&#34;,&#34;priceBox&#34;:{&#34;supIndexMonthlyFeeLabel&#34;:&#34;Sup Index for MonthlyFeeLabel&#34;,&#34;i18n_dealerPriceCardLabel&#34;:&#34;Total price&#34;,&#34;telephoneLabelPriceCard&#34;:&#34;Tel: &#34;,&#34;monthlyFeeLabel&#34;:&#34;Monthly Fee Label&#34;,&#34;vinNumberLabel&#34;:&#34;VIN&#34;,&#34;importerSubtitle&#34;:&#34;Importer Subtitle&#34;,&#34;importerTitle&#34;:&#34;Importer&#34;,&#34;priceCardPrimaryCtaClass&#34;:&#34;btn btn-standard btn-black btn-block&#34;,&#34;priceCardPrimaryCtaStyle&#34;:&#34;outline&#34;,&#34;priceCardPrimaryCtaTitle&#34;:&#34;Enquire now&#34;,&#34;priceCardPrimaryCtaTarget&#34;:&#34;_self&#34;,&#34;showVinNumber&#34;:&#34;true&#34;,&#34;currency&#34;:&#34;£&#34;,&#34;showCurrencyBefore&#34;:&#34;true&#34;,&#34;supIndexLabel&#34;:&#34;Sup Index for Price&#34;,&#34;priceCardPrimaryCtaLink&#34;:&#34;https://featureapps.seat.co.uk/stock-locator-form/2.2.0/index.html&#34;},&#34;priceBoxWebcalc&#34;:{&#34;showPickupPoint&#34;:&#34;false&#34;,&#34;priceBoxCtaCheckoutTarget&#34;:&#34;_self&#34;,&#34;showCheckbox&#34;:&#34;false&#34;,&#34;showPriceBoxContactCTA&#34;:&#34;false&#34;,&#34;showCurrencyBeforeWebcalc&#34;:&#34;false&#34;,&#34;priceBoxCtaContactTarget&#34;:&#34;_self&#34;,&#34;pickupPoint&#34;:{&#34;button&#34;:{}},&#34;dealerSearch&#34;:{&#34;brandCupra&#34;:&#34;false&#34;}}},&#34;resultPage&#34;:{&#34;generalUI&#34;:{&#34;hideResultsCounter&#34;:&#34;false&#34;},&#34;productCard&#34;:{&#34;displayMode&#34;:&#34;european-country&#34;,&#34;technicalData&#34;:{&#34;exteriorColorLabel&#34;:&#34;Colour: &#34;,&#34;technicalDataLabelsVisible&#34;:&#34;true&#34;},&#34;usedCarsData&#34;:{},&#34;efficiencyData&#34;:{&#34;efficiencyDataSource&#34;:&#34;wltp&#34;,&#34;emissionsLabel&#34;:&#34;WLTP CO₂ Emissions (Combined)¹:&#34;,&#34;efficiencyDataLabelsVisible&#34;:&#34;true&#34;,&#34;fuelConsumptionLabel&#34;:&#34;WLTP Fuel Consumption (Combined)¹:&#34;},&#34;deliveryTime&#34;:{&#34;deliveryTimeTooltipVisible&#34;:&#34;false&#34;,&#34;deliveryTimeMode&#34;:&#34;minDeliveryTime&#34;,&#34;deliveryTimeVisible&#34;:&#34;false&#34;},&#34;pickupPoint&#34;:{&#34;pickupPointVisible&#34;:&#34;true&#34;},&#34;prices&#34;:{&#34;showCurrencyBeforePrice&#34;:&#34;true&#34;,&#34;postCurrencySymbol&#34;:&#34;*&#34;,&#34;currencySymbol&#34;:&#34;£&#34;,&#34;totalPrice&#34;:{&#34;showStrikedTotalPrice&#34;:&#34;false&#34;,&#34;totalPriceLabel&#34;:&#34;On The Road Price&#34;,&#34;showTotalPrice&#34;:&#34;false&#34;},&#34;dealerPrice&#34;:{&#34;showDealerPrice&#34;:&#34;true&#34;,&#34;dealerPriceLabel&#34;:&#34;Total price&#34;},&#34;quotePrice&#34;:{&#34;quotePriceLabel&#34;:&#34;Quote Price&#34;,&#34;showQuotePrice&#34;:&#34;false&#34;},&#34;driveAwayPrice&#34;:{&#34;showDriveAwayPrice&#34;:&#34;false&#34;,&#34;driveAwayPriceLabel&#34;:&#34;Drive Away Price&#34;}},&#34;financialData&#34;:{&#34;financialDataTitle&#34;:&#34;Finance&#34;,&#34;showFinancialData&#34;:&#34;false&#34;}},&#34;footerPage&#34;:{&#34;staticDisclaimer&#34;:&#34;&lt;p>&lt;u>Legal note:&lt;/u>&lt;/p>\r\n&lt;p>The display of vehicles and search results does not create a contract or other binding obligation and is subject to change without notice. It is not an offer capable of acceptance.&lt;/p>\r\n&lt;p>Every effort has been made to ensure the accuracy of the information above. However, errors may occur and SEAT UK cannot guarantee the information provided will be up-to-date, accurate, complete and precise and does not assume liability for it. It is possible that vehicles may be incorrectly priced, described or pictured within this tool or may already be subject to other enquiries or may have been sold. Check with your local participating SEAT Retailer about items which may affect your decision to purchase.&lt;/p>\r\n&lt;p>Standard vehicle equipment is automatically populated from separate systems and sometimes may vary from the actual car. Always speak to the SEAT Retailer to confirm the most up to date availability, price, specification and other vehicle information before placing your order.&lt;/p>\r\n&lt;p>Lead times are indicative only.&lt;/p>\r\n&lt;p>&lt;i>Reserve Online&lt;/i>&lt;/p>\r\n&lt;p>The &amp;quot;Reserve Online&amp;quot; option is not a vehicle order. Once you have completed the reservation process (in accordance with the &lt;a href=\&#34;https://www.seat.co.uk/about-seat/legal/new-car-reservation-terms\&#34;>terms and conditions&lt;/a>), you will receive an email to confirm that your request has been passed to the relevant SEAT Retailer. Once reserved, your vehicle will be reserved for a period of seven (7) days.&lt;/p>\r\n&lt;p>In order to reserve a vehicle, a credit card pre-authorisation of £99 is required. This pre-authorisation does not debit your bank account. The amount is blocked for a period of seven (7) days. After this period, the credit card pre-authorisation is automatically cancelled, without you having to act and without any further information from us or your bank. Please note the credit card pre-authorisation cannot be returned any sooner than the period imposed by your bank (please check with your bank for details).&lt;/p>\r\n&lt;p>Once your vehicle is reserved, it will be visible on the New Car Stock Locator Tool with a &amp;quot;reserved&amp;quot; banner. However, &lt;b>no &amp;quot;holds&amp;quot; will be placed on the car in the vehicle ordering system. It is, therefore, possible your vehicle may be offered to other customers and may be sold during the Reservation Period.&lt;/b>&lt;/p>\r\n&lt;p>The vehicle will only be removed from the New Car Stock Locator Tool when you have purchased it (i.e. when you have entered into an agreement for purchase of the vehicle).&lt;/p>\r\n&lt;p>After the seven (7) day reservation period, SEAT UK or the SEAT Retailer may offer the vehicle to other customers, even if your credit card pre-authorisation has not yet expired and the £99 is still blocked within your account.&lt;/p>\r\n&lt;p>The vehicles displayed are not updated in real time and so it is possible that you may reserve a vehicle which may already be subject to other enquiries or reservations or may have already been sold by SEAT UK or the SEAT Retailer or is otherwise not available. In this instance, your SEAT Retailer will respond to your reservation accordingly, making you aware of alternative vehicles that are available.&lt;/p>\r\n&lt;p>The sale agreement for any vehicle reserved is not concluded on the Site and you will need to visit the applicable SEAT Retailer to make your purchase.&lt;/p>\r\n&lt;p>&lt;b>* If you are reserving a SEAT vehicle: &lt;/b>You will need to place an order to purchase the vehicle with your chosen SEAT Retailer.&lt;/p>\r\n&lt;p>We may close the reservation scheme to new applicants for any reason at any time. We will endeavour to provide notice on the Site before closing access to the scheme.&lt;/p>\r\n&lt;p>&lt;i>Pricing, figures and specification&lt;/i>&lt;/p>\r\n&lt;p>&lt;b>* If you are reserving a SEAT vehicle &lt;/b>then prices shown are the manufacturer&#39;s recommended On The Road (OTR) retail price. Actual prices are set by SEAT authorised retailers in their sole discretion – always obtain these prices from your chosen SEAT Retailer. Recommended On-The-Road (OTR) retail prices include: delivery charge, number plates, new vehicle registration fee, the first year&#39;s Vehicle Excise Duty and VAT (calculated at 20%).&lt;/p>\r\n&lt;p>Prices, specifications and other vehicle information are subject to change without notice and may therefore differ at the time of order from the prices and other vehicle information displayed in the New Car Stock Locator Tool. Please speak to the relevant SEAT Retailer to confirm the most up to date availability, price, specification and other vehicle information.&lt;/p>\r\n&lt;p>Performance figures and specifications relating to SEAT vehicles are indicative only and performance cannot be guaranteed. Performance figures and specifications may be updated on this site from time to time. The applicable SEAT Retailer can always provide you with the most up-to-date information available.&lt;/p>\r\n&lt;p>† All vehicles are tested according to WLTP technical procedures. Figures shown are for comparability purposes; only compare fuel consumption, range and CO2 and equivalent electric range figures with other vehicles tested to the same technical procedures. These figures may not reflect real life driving results, which will depend upon a number of factors including the accessories fitted (post-registration), variations in weather, driving styles, vehicle load (and, for battery electric vehicles, the starting charge of the battery). Figures for plug-in hybrid vehicles were obtained using a combination of battery power and fuel. Plug-in hybrid vehicles require mains electricity for charging. Figures for battery electric vehicles were obtained after the battery had been fully charged. Battery electric vehicles require mains electricity for charging. Zero emissions while driving.&lt;/p>\r\n&lt;p>All figures quoted are subject to change due to ongoing approvals/changes and range figures may include options not available in the UK. Please consult your participating SEAT Retailer for further information.&lt;/p>\r\n&lt;p>Technical and connected features may be subject to system limits and requirements, including compatibility, network or wi-fi coverage, restriction and app-download, subscription to digital services, etc. Please visit our SEAT Connect page for more information on these features and relevant terms and conditions.&lt;/p>\r\n&lt;p>Speed and system limits apply to driver assistance technologies. Driver assistance only – driver must pay attention to the road and retain control at all times.&lt;/p>\r\n&lt;p>Please note it is not possible to retrospectively fit a tow bar if the car is not fitted with tow bar preparation.&lt;/p>\r\n&lt;p>Where a vehicle is described as &amp;quot;&lt;i>National stock – available at any Retailer&lt;/i>&amp;quot; the cars displayed are not currently at any particular SEAT Retailer and are available to purchase from all participating SEAT Retailers. If you wish to select a specific SEAT Retailer, you will need to enter a different postcode. Subject to availability, your local participating SEAT Retailer will need to purchase the vehicle from SEAT UK ahead of your purchase.&lt;/p>\r\n&#34;}},&#34;stockTypeFilter&#34;:{&#34;usedCarsVisible&#34;:&#34;true&#34;},&#34;onlineServices&#34;:{&#34;virtualShowRoomFilterVisible&#34;:&#34;false&#34;,&#34;onlineCarsFilterVisible&#34;:&#34;false&#34;,&#34;virtualShowRoomFilter&#34;:{},&#34;onlineCarsFilter&#34;:{}},&#34;webcalcInterface&#34;:{},&#34;modelFilterAssociation&#34;:{&#34;BHBC&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/seat-mii.png&#34;,&#34;BHBN&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/seat-mii-electric.png&#34;,&#34;BHAB&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/ibiza.png&#34;,&#34;BHAI&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/leon.png&#34;,&#34;BHBK&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/leon-st.png&#34;,&#34;BHBO&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/arona.png&#34;,&#34;BHAF&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/alhambra.png&#34;,&#34;BHBM&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/ateca.png&#34;,&#34;BHBP&#34;:&#34;/content/dam/public/seat-website/carworlds/stock-locator/models/new-models/tarraco.png&#34;},&#34;colorFilterAssociation&#34;:{&#34;00&#34;:&#34;/content/dam/public/seat-website/generic/icons/stock-locator-icons/color-unavailable.png&#34;,&#34;01&#34;:&#34;/content/dam/public/seat-website/generic/icons/stock-locator-icons/blue.svg&#34;,&#34;13&#34;:&#34;/content/dam/public/seat-website/generic/icons/stock-locator-icons/orange.png&#34;,&#34;02&#34;:&#34;/content/dam/public/seat-website/generic/icons/stock-locator-icons/green.svg&#34;,&#34;03&#34;:&#34;/content/dam/public/seat-website/generic/icons/stock-locator-icons/red.svg&#34;,&#34;14&#34;:&#34;/content/dam/public/seat-website/generic/icons/stock-locator-icons/purple.svg&#34;,&#34;04&#34;:&#34;/content/dam/public/seat-websit