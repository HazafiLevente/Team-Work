":{\"id\":\"1\",\"slug\":\"mobile\",\"title\":\"گوشی\",\"englishTitle\":\"mobile\"}}],\"isDynamic\":true,\"hasShowMore\":false,\"id\":\"65be35ea0d2f6d4df9ad3ccf\",\"title\":\"داغ‌ترین محصولات 🔥\"},{\"id\":\"6666dea4bf5b9e04040495dd\",\"title\":\"پربحث‌ترین‌ها\"},{\"id\":\"6575976e9752f0b84adbca4d\",\"title\":\"لپ‌تاپ\"},{\"id\":\"657587c19752f0b84adbca3e\",\"title\":\"گوشی\"},{\"id\":\"653929d8661214102e772d1c\",\"title\":\"هدفون\"},{\"id\":\"65378574661214102e772cd7\",\"title\":\"کنسول بازی\"},{\"id\":\"6536de78661214102e772cad\",\"title\":\"لوازم خانگی\"},{\"id\":\"6575a8419752f0b84adbca60\",\"title\":\"تلویزیون\"},{\"id\":\"6575a6cb9752f0b84adbca58\",\"title\":\"تبلت\"},{\"id\":\"658828919752f0b84adbcad6\",\"title\":\"لوازم جانبی گوشی\"},{\"id\":\"65882ab19752f0b84adbcad9\",\"title\":\"سخت‌افزار\"},{\"id\":\"65378869661214102e772ce7\",\"title\":\"حافظه‌ ذخیره‌سازی\"}],\"title\":\"مقایسه قیمت و مشخصات 🛒\",\"template\":\"PD-1\",\"desktopTemplate\":\"PD-1\",\"mobileTemplate\":\"PM-1\",\"itemsCount\":42,\"id\":\"657587d19752f0b84adbca40\",\"type\":\"ProductList\",\"priority\":4,\"zone\":{\"pageId\":\"home\",\"positionId\":\"boxUnderMainContent\",\"includedUrlPatterns\":[],\"excludedUrlPatterns\":[],\"isMobileSupported\":true,\"isDesktopSupported\":true},\"isTitleVisibleOnWebSite\":true,\"origin\":\"Internal\"},{\"chips\":[{\"items\":[{\"id\":\"35023\",\"slug\":\"Biographies\",\"title\":\"بیوگرافی بزرگان علم و فناوری\",\"cover\":{\"id\":\"65dc733f412e5bb22d865ec1\",\"fileName\":\"biography\",\"alt\":\"کالکشن بیوگرافی\",\"preview\":\"\",\"width\":0,\"height\":0},\"articlesCount\":47,\"rawTopDescription\":\"\\nبا زندگی و دستاوردهای استادان نوآوری و شکل‌دهندگان دنیای علم و تکنولوژی آشنا شوید.\"},{\"id\":\"35022\",\"slug\":\"worlds-little-mysteries\",\"title\":\"رازهای کوچک جهان\",\"cover\":{\"id\":\"65dc4c22b5484d0cca6f6913\",\"fileName\":\"small-things\",\"alt\":\"کالکشن «چیزهای کوچک»\",\"preview\":\"\",\"width\":0,\"height\":0},\"articlesCount\":69,\"rawTopDescription\":\"\\nجهان اطراف ما مملو از پدیده‌هایی به‌ظاهر ساده اما علمی و شگفت‌انگیز است. در این بخش از زومیت، به بررسی رازهای کوچک اما مهم درباره دنیای اطرافمان می‌پردازیم و پاسخ‌هایی دقیق و علمی برای پرسش‌هایی ارائه می‌دهیم که شاید همیشه از خودمان می‌پرسیدیم.\"},{\"id\":\"35021\",\"slug\":\"what-happens-if\",\"title\":\"چه می‌شد اگر؟\",\"cover\":{\"id\":\"65dc4bb0412e5bb22d865dd7\",\"fileName\":\"what-happen-if\",\"alt\":\"کالکشن «چه می‌شد اگر»\",\"preview\":\"\",\"width\":0,\"height\":0},\"articlesCount\":21,\"rawTopDescription\":\"\\nدر این بخش از زومیت، به دنیای پرسش‌های فرضی و شگفت‌انگیز قدم می‌گذاریم؛ جایی که علم با تخیل تلاقی و به ما کمک می‌کند تا تصور کنیم دنیا در سناریوهای غیرواقعی چگونه می‌توانست باشد. با تحلیل‌های علمی و نگاهی سرگرم‌کننده، به سوالاتی پاسخ می‌دهیم که ذهن کنجکاو هر انسانی را قلقلک می‌دهند.\"},{\"id\":\"35020\",\"slug\":\"walk-streets-silicon-valley\",\"title\":\"پرسه در سیلیکون ولی\",\"cover\":{\"id\":\"65d1bf5d381b5915be4f4584\",\"fileName\":\"silicon-valley\",\"alt\":\"لوگوی شرکت‌های تکنولوژی با اپل پارک در پس‌زمینه\",\"preview\":\"\",\"width\":0,\"height\":0},\"articlesCount\":30,\"rawTopDescription\":\"\\nروایت‌های خواندنی از دنیای فناوری؛ در این مجموعه، با ماجرای جذاب‌ترین رویدادها، نوآوری‌ها و داغ‌ترین ترندهای تکنولوژی آشنا شوید.\"},{\"id\":\"35019\",\"slug\":\"android-tricks\",\"title\":\"ترفند ها و آموزش های اندروید\",\"cover\":{\"id\":\"65d1c063c601123d654e31c6\",\"fileName\":\"android-tt\",\"alt\":\"لوگوی اندروید \",\"preview\":\"\",\"width\":0,\"height\":0},\"articlesCount\":61,\"rawTopDescription\":\"\\nدر مجموعه مطالعاتی آموزش اندروید با برترین و کاربردی‌ ترین ترفند های اندروید آشنا خواهید شد و صفر تا صد تبلت و گوشی اندرویدی خود را آموزش می‌بینید.\"},{\"id\":\"35018\",\"slug\":\"hardware-deep-dive\",\"title\":\"شیرجه در سخت افزار\",\"cover\":{\"id\":\"65d1c062c601123d654e31bd\",\"fileName\":\"hardware\",\"alt\":\"طرح مفهومی سخت‌افزار \",\"preview\":\"\",\"width\":0,\"height\":0},\"articlesCount\":14,\"rawTopDescription\":\"\\nبا مقالات سخت‌افزاری زومیت در دریای هیجان‌انگیز سخت‌افزار از CPU و GPU تا هوش مصنوعی و شرکت‌های فناوری پیشرو شیرجه بزنید.\"},{\"id\":\"35017\",\"slug\":\"tech-nostalgia\",\"title\":\"ماشین زمان\",\"cover\":{\"id\":\"65d1c8d6c601123d654e31f0\",\"fileName\":\"nostalgia\",\"alt\":\"پیکان زرد در کنار کنسول گیم‌بوی و نوکیا 6600\",\"preview\":\"\",\"width\":0,\"height\":0},\"articlesCount\":19,\"rawTopDescription\":\"\\nبا مقالات «ماشین زمان» به گذشته دنیای فناوری سفر کنید و همراه ما محصولات و تکنولوژی‌های نوستالژیک را مرور کنید.\"},{\"id\":\"35016\",\"slug\":\"solar-system\",\"title\":\"آشنایی با منظومه شمسی\",\"cover\":{\"id\":\"65d1c063381b5915be4f45a5\",\"fileName\":\"stars\",\"alt\":\"طرح مفهومی از منظومه شمسی\",\"preview\":\"\",\"width\":0,\"height\":0},\"articlesCount\":15,\"rawTopDescription\":\"\\nمنظومه شمسی، این محله وسیع و درعین‌حال کوچک ما در فضای بی‌کران، مملو از اجرام شگفت‌انگیز، ازجمله سیاره آبی منحصربه‌فردمان است.در این بخش با هرآنچه لازم است درباره منظومه شمسی بدانید، آشنا می‌شوید.\"},{\"id\":\"35015\",\"slug\":\"infinite-engineering\",\"title\":\"مهندسی بی‌نهایت\",\"cover\":{\"id\":\"693576de7770ed636f3471b3\",\"fileName\":\"infinite-engineering\",\"alt\":\"مهندسی بی نهایت\",\"width\":1920,\"height\":1280},\"articlesCount\":52,\"rawTopDescription\":\"\\nروایت ساخت پیچیده‌ترین و خلاقانه‌ترین سازه‌های دست بشر؛ از مهندسی دقیق تلسکوپ‌های فضایی تا عظمت آسمان‌خراش‌هایی که ابرها را می‌شکافند. در بخش «مهندسی بی‌نهایت» ببینید که چگونه علم و جسارت، مرزهای غیرممکن را جابه‌جا می‌کنند.\"},{\"id\":\"35036\",\"slug\":\"survival-crisis-guide\",\"title\":\"راهنمای بقا و آمادگی در شرایط بحرانی و اضطراری\",\"cover\":{\"id\":\"6890b0eb4a11743828d579e4\",\"fileName\":\"survival-crisis-guide\",\"width\":1920,\"height\":1280},\"articlesCount\":73,\"rawTopDescription\":\"\\nزندگی همیشه در مسیر آرام پیش نمی‌رود؛ بحران‌ها و حوادث ممکن است ناگهان از راه برسند. با راهنمای بقا و آمادگی زومیت، مهارت‌ها و دانشی را بیاموزید که می‌تواند در شرایط سخت، تفاوت بین خطر و امنیت را رقم بزند.\"}],\"id\":\"650eb7bfa07c04a05f11559f\",\"title\":\"فهرست‌های مطالعاتی\"}],\"title\":\"فهرست‌های مطالعاتی\",\"template\":\"collectionSlider\",\"desktopTemplate\":\"collectionSlider\",\"mobileTemplate\":\"collectionSlider\",\"itemsCount\":10,\"id\":\"650eb7e4a07c04a05f1155a1\",\"type\":\"ArticleCollection\",\"priority\":3,\"zone\":{\"pageId\":\"home\",\"positionId\":\"boxUnderMainContent\",\"includedUrlPatterns\":[],\"excludedUrlPatterns\":[],\"isMobileSupported\":true,\"isDesktopSupported\":true},\"isTitleVisibleOnWebSite\":true,\"origin\":\"Internal\"}],\"boxUnderShowcase\":[{\"chips\":[{\"items\":[{\"id\":\"2381\",\"title\":\"هوش مصنوعی نژاد پرست!\",\"isExclusive\":true,\"type\":\"Vertical\",\"coverImage\":{\"id\":\"69b41802f235c5d0902b3f1e\",\"fileName\":\"racist-ai\",\"alt\":\"Rasist AI\",\"preview\":\"\",\"width\":1080,\"height\":1920},\"playedCount\":132892,\"likesCount\":311,\"duration\":\"00:01:41\",\"playlists\":[],\"sources\":{\"aparatSource\":{\"content\":\"\"},\"youtubeSource\":{},\"localSource\":{\"mediaId\":\"69b417e4f235c5d0902b3edf\"}},\"mainAddress\":\"https://www.zoomit.ir/shorts/2381\"},{\"id\":\"2380\",\"title\":\"فراموشی کلمات با قطعی اینترنت\",\"isExclusive\":true,\"type\":\"Vertical\",\"coverImage\":{\"id\":\"69b044dbf235c5d0902b363d\",\"fileName\":\"internet-shutdown\",\"alt\":\"internet shutdown\",\"preview\":\"\",\"width\":1080,\"height\":1920},\"playedCount\":144267,\"likesCount\":730,\"duration\":\"00:01:30\",\"playlists\":[],\"sources\":{\"aparatSource\":{\"content\":\"\"},\"youtubeSource\":{},\"localSource\":{\"mediaId\":\"69b043f5f235c5d0902b3604\"}},\"mainAddress\":\"https://www.zoomit.ir/shorts/2380\"},{\"id\":\"2379\",\"title\":\"وقتی خرید، تسکین‌دهنده‌ی ناامیدی می‌شود \",\"isExclusive\":true,\"type\":\"Vertical\",\"coverImage\":{\"id\":\"69aec3e3f235c5d0902b3179\",\"fileName\":\"lipstick-effect\",\"alt\":\"اثر رژ لب\",\"preview\":\"\",\"width\":1080,\"height\":1920},\"playedCount\":105644,\"likesCount\":474,\"duration\":\"00:01:04\",\"playli